# ============================================================
# VibeVoice-ASR 內部部署平台 — 環境變數範本
# Copy to .env and fill in your values
# ============================================================

# === Deployment Profile ===
# single | single-large | dual-split | dual-tp | multi
DEPLOYMENT_PROFILE=single
GPU_INFERENCE_DEVICES=0
GPU_TRAINING_DEVICES=0
WORKER_REPLICAS=1

# === vLLM ===
VLLM_BASE_URL=http://host.docker.internal:8000
VLLM_CONTAINER_NAME=vibevoice-vllm
VLLM_TENSOR_PARALLEL=1
VLLM_DATA_PARALLEL=1
VLLM_MAX_MODEL_LEN=65536
VLLM_MAX_NUM_SEQS=64
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_DEFAULT_MODEL=microsoft/VibeVoice-ASR
VLLM_DOCKER_IMAGE=vllm/vllm-openai:v0.14.1

# === Backend ===
BACKEND_PORT=8080
BACKEND_DB_URL=sqlite:////data/app.db
BACKEND_LOG_LEVEL=INFO
BACKEND_DATA_DIR=/data
BACKEND_MAX_UPLOAD_MB=500

# === Frontend ===
FRONTEND_PORT=5173

# === Audio Limits ===
MAX_AUDIO_DURATION_SEC=14400        # 4 hours hard limit
AUTO_SPLIT_THRESHOLD_SEC=3300       # > 55 min auto-split
SPLIT_CHUNK_DURATION_SEC=3000       # 50 min per chunk
SPLIT_OVERLAP_SEC=5
SYNC_AUDIO_MAX_DURATION_SEC=120     # /api/v1/transcribe/sync limit

# === Redis & Queue ===
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
WORKER_MAX_JOBS=8
WS_IDLE_TIMEOUT_SEC=60

# === Training ===
TRAIN_DOCKER_IMAGE=vibevoice-train:latest

# === HuggingFace ===
# HF_CACHE_HOST is the HOST path mounted into vLLM container as /root/.cache/huggingface.
# Default: ./data/hf_cache (project-local).
# Override examples (sharing existing cache):
#   HF_CACHE_HOST=C:\Users\you\.cache\huggingface     # Windows
#   HF_CACHE_HOST=/home/you/.cache/huggingface        # Linux
#   HF_CACHE_HOST=$HOME/.cache/huggingface            # macOS (note: docker-compose may not expand $HOME — use absolute)
HF_CACHE_HOST=./data/hf_cache
HF_HUB_OFFLINE=0

# === Webhook ===
WEBHOOK_TIMEOUT_SEC=30
WEBHOOK_MAX_ATTEMPTS=7

# === API Key ===
API_KEY_PREFIX=vva_
API_KEY_LENGTH=32

# === Idempotency ===
IDEMPOTENCY_TTL_SEC=86400           # 24 hours

# === Observability ===
METRICS_ENABLED=true
